# Shared service URLs (used by backend)
CLASSIFIER_URL=http://classifier:8001
GUIDANCE_URL=http://guidance:8002

# Classifier runtime
CLASSIFIER_DEVICE=cuda
MODEL_PATH=/app/weights/student_best.pt
WHISPER_MODEL_SIZE=Systran/faster-whisper-base
DEFAULT_THRESHOLD=0.5

# Backend
CORS_ORIGINS=*
CLASSIFIER_TIMEOUT=180
GUIDANCE_TIMEOUT=30

# Frontend publish port
FRONTEND_PORT=80
